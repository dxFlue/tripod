{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Tripod React Native (Expo)",
  "extends": "./react.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "noEmit": true,
    "resolveJsonModule": true
  }
}
