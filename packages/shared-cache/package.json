{
  "name": "@tripod-stack/shared-cache",
  "version": "0.0.0",
  "description": "Tripod 缓存抽象：CacheProvider 接口 + InMemory impl + @Cacheable",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "@tripod-stack/shared-contract": "workspace:*",
    "@tripod-stack/shared-types": "workspace:*"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@tripod-stack/eslint-config": "workspace:*",
    "@tripod-stack/tsconfig": "workspace:*",
    "eslint": "^8.57.0",
    "eslint-plugin-tripod": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
